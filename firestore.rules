rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// (or paste directly into Firebase Console → Firestore Database → Rules)

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can read/write ONLY their own profile document.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Creation happens via our own app code right after signup (see
      // lib/firestoreUser.js) — still gated to the account's own uid.
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // handle account deletion via a server-side flow, not client rules

      // Tasks and notifications are private to their owner.
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
